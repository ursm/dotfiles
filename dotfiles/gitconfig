[alias]
	br = branch
	ca = commit -v --amend
	ci = commit -v
	ds = diff --staged
	lg = log --oneline --decorate --graph
	lp = log -p --stat
	pr = pull --rebase --prune
	st = status -sb
[color]
	ui = auto
[user]
	name = Keita Urashima
	email = ursm@ursm.jp
	signingkey = 360E323EB0CBCC6E33D8BEEB6A6A5D90F612A885
[github]
	user = ursm
[push]
	default = tracking
	followTags = true
[heroku]
	account = ursm
[ghq]
	root = ~/src
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	required = true
[credential]
	helper = libsecret
[gpg]
	program = gpg2
[rebase]
	autostash = true
	autosquash = true
[pull]
	rebase = true
[init]
	defaultBranch = main
[core]
	pager = delta --diff-highlight
[interactive]
	diffFilter = delta --color-only --diff-highlight
