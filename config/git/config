[alias]
	br = branch
	ca = commit --amend
	ci = commit
	cp = cherry-pick
	ds = diff --staged
	lg = log --oneline --decorate --graph
	lp = log --patch
	pr = pull --rebase --prune
	st = status
[color]
	ui = auto
[commit]
	verbose = true
	gpgsign = 1
[credential]
	helper = libsecret
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	required = true
[ghq]
	root = /home/ursm/Repositories
[github]
	user = ursm
[gpg]
	program = gpg2
[heroku]
	account = ursm
[init]
	defaultBranch = main
[log]
	date = iso
[pull]
	rebase = true
[push]
	default = tracking
[rebase]
	autoStash = true
	autoSquash = true
[user]
	name = Keita Urashima
	email = ursm@ursm.jp
	signingkey = 31F7FAA07C3C63994091956C95B966221E4F9294
[core]
	quotepath = off
[diff]
	tool = vimdiff
[merge]
	tool = vimdiff
[maintenance]
	repo = /var/db/repos/gentoo
	repo = /var/db/repos/go-overlay
	repo = /var/db/repos/guru
