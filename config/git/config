[alias]
	br = branch
	ca = commit --amend
	can = commit --amend --no-edit
	ci = commit
	cp = cherry-pick
	ds = diff --staged
	lg = log --oneline --decorate --graph
	lp = log --patch
	pr = pull --rebase --prune
	st = status
	ps = push
	psf = push --force-with-lease
[color]
	ui = auto
[commit]
	verbose = true
	gpgsign = 1
[credential]
	helper = libsecret
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	required = true
[ghq]
	root = /home/ursm/Repositories
[github]
	user = ursm
[gpg]
	program = gpg2
[heroku]
	account = ursm
[init]
	defaultBranch = main
[log]
	date = iso
[pull]
	rebase = true
[push]
	default = tracking
[rebase]
	autoStash = true
	autoSquash = true
[user]
	name = Keita Urashima
	email = ursm@ursm.jp
	signingkey = BABF2B185CCA1E5CB043AF877184AF0D403D45AF
[core]
	quotepath = off
[diff]
	tool = vimdiff
	algorithm = histogram
	colorMoved = dimmed-zebra
[merge]
	tool = vimdiff
[maintenance]
	repo = /var/db/repos/gentoo
	repo = /var/db/repos/go-overlay
	repo = /var/db/repos/guru
