[alias]
	br = branch
	ca = commit --amend
	ci = commit
	cp = cherry-pick
	ds = diff --staged
	lg = log --oneline --decorate --graph
	lp = log -p --stat
	pr = pull --rebase --prune
	st = status --short --branch
[color]
	ui = auto
[commit]
	verbose = true
	gpgsign = 1
[credential]
	helper = libsecret
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	required = true
[ghq]
	root = ~/Repositories
[github]
	user = ursm
[gpg]
	program = gpg2
[heroku]
	account = ursm
[init]
	defaultBranch = main
[log]
	date = iso
[pull]
	rebase = true
[push]
	default = tracking
[rebase]
	autostash = true
	autosquash = true
[user]
	name = Keita Urashima
	email = ursm@ursm.jp
	signingkey = 360E323EB0CBCC6E33D8BEEB6A6A5D90F612A885
[maintenance]
	repo = /home/ursm/.local/share/znap/anyframe
	repo = /home/ursm/.local/share/znap/asdf
	repo = /home/ursm/.local/share/znap/ohmyzsh
	repo = /home/ursm/.local/share/znap/zsh-completions
	repo = /home/ursm/.local/share/znap/zsh-snap
	repo = /home/ursm/.local/share/znap/zsh-syntax-highlighting
